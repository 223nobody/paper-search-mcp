# Local configuration and secrets
# paper-search-mcp unified environment configuration
# Copy this file to .env and fill in the values you need.
# Preferred format: PAPER_SEARCH_MCP_<NAME>

# Core optional keys/tokens
PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY=
PAPER_SEARCH_MCP_CORE_API_KEY=
PAPER_SEARCH_MCP_UNPAYWALL_EMAIL=
PAPER_SEARCH_MCP_DOAJ_API_KEY=
PAPER_SEARCH_MCP_ZENODO_ACCESS_TOKEN=
PAPER_SEARCH_MCP_GOOGLE_SCHOLAR_PROXY_URL=

# Parser/cache configuration
PAPER_SEARCH_MCP_CACHE_DIR=.paper_search_cache
# MCP tools default to ~/Desktop/papers for PDF downloads. Custom save_path
# values require custom_save_path_confirmed=true unless this guard is disabled.
PAPER_SEARCH_MCP_REQUIRE_EXPLICIT_SAVE_PATH=true
# Set this to false to force the default directory even after explicit confirmation.
PAPER_SEARCH_MCP_ALLOW_CUSTOM_SAVE_PATH=true
# =============================================================================
# PDF-first CS source policy, smoke-tested 2026-06-20
# =============================================================================
# Goal: find and download PDFs for computer-science papers, then send PDFs to
# MinerU. Markdown-only full text is not treated as a successful PDF result.
#
# Enabled by default:
# arxiv    : primary CS PDF source. Search passed quickly in smoke tests; PDF
#            download can still be network-sensitive, so OpenAlex arXiv PDF
#            links remain a useful backup signal.
# openalex : broad metadata/OA discovery. Smoke test returned arXiv DOI and
#            direct arXiv PDF URL for a RAG query.
# dblp     : CS bibliography. Smoke test was fast and returned DOI metadata;
#            it does not host PDFs, so use it only for discovery/DOI fallback.
# crossref : DOI and metadata backbone. Smoke test was slow but can expose
#            direct PDF links. Keep enabled for DOI enrichment and dedupe.
PAPER_SEARCH_MCP_SEARCH_PROFILE=pdf-cs
#
# Temporarily disabled despite CS relevance:
# semantic       : requires API key; set PAPER_SEARCH_MCP_SEMANTIC_SCHOLAR_API_KEY
#                  to enable. Provides title/abstract search and citation graph.
# iacr           : CS/crypto relevant. Search may return PDF URLs, but direct
#                  download can return HTTP 403; keep disabled until the
#                  downloader is hardened with correct headers/fallback.
# citeseerx      : request path may time out through web.archive.org.
# google_scholar : timed out and is bot-detection prone; discovery only, no PDF.
# ieee,acm       : require keys/legal access; set PAPER_SEARCH_MCP_IEEE_API_KEY
#                  or PAPER_SEARCH_MCP_ACM_API_KEY to enable.
#
# Disabled as not CS-primary or not PDF-reliable for this workflow:
# pubmed,pmc,europepmc,biorxiv,medrxiv : biomedical/life-science focus.
# doaj,base,zenodo,hal,openaire        : repository/journal sources are useful
#                                        in some domains but record-dependent.
# ssrn                                 : social-science focus; anti-bot/login
#                                        restrictions are common.
# core                                 : requires API key; set PAPER_SEARCH_MCP_CORE_API_KEY
#                                        to enable. Serves as download-fallback
#                                        repository when enabled.
PAPER_SEARCH_MCP_DISABLED_SOURCES=pubmed,biorxiv,medrxiv,google_scholar,iacr,semantic,pmc,core,europepmc,citeseerx,doaj,base,zenodo,hal,ssrn,unpaywall,openaire
#
# Search profile resolution:
# SEARCH_PROFILE=pdf-cs resolves to: arxiv,openalex,crossref,dblp.
# Use sources=deep or sources=all only when you explicitly want slower
# long-tail sources. Runtime candidate ranking also applies PDF-first
# reliability scoring.
PAPER_SEARCH_MCP_SEARCH_TIMEOUT_SECONDS=18
PAPER_SEARCH_MCP_SEARCH_SOURCE_TIMEOUT_SECONDS=12
PAPER_SEARCH_MCP_SEARCH_CACHE_TTL_SECONDS=300
# Prefer arxiv PDF URLs and identifiers when a paper is available from
# multiple sources. Set to false to disable the arxiv priority boost.
PAPER_SEARCH_MCP_PREFER_ARXIV=true
PAPER_SEARCH_MCP_ARXIV_TIMEOUT_SECONDS=8
PAPER_SEARCH_MCP_ARXIV_MAX_ATTEMPTS=2
PAPER_SEARCH_MCP_DOWNLOAD_TIMEOUT_SECONDS=30
PAPER_SEARCH_MCP_DOWNLOAD_MAX_RETRIES=3
PAPER_SEARCH_MCP_DOWNLOAD_RETRY_BACKOFF_SECONDS=1.0
# Download strategy: race keeps the current concurrent OA race; oa_first tries
# OA routes before opt-in non-OA fallbacks; sequential tries routes one by one.
PAPER_SEARCH_MCP_DOWNLOAD_STRATEGY=race
# Optional integration point for Dictation354/paper-fetch-skill. Disabled by
# default because it requires the paper_fetch Python package and should be
# re-tested in this project environment. When true, it is used only after the
# existing OA fallback chain fails, and only a validated PDF counts as success.
PAPER_SEARCH_MCP_PAPER_FETCH_PDF_FALLBACK=false
# Optional LibGen fallback. Disabled by default and used only when explicitly
# enabled via this env var or the use_libgen tool parameter.
PAPER_SEARCH_MCP_LIBGEN_ENABLED=false
PAPER_SEARCH_MCP_LIBGEN_BASE_URL=
# How many papers to download in parallel (default: 8)
PAPER_SEARCH_MCP_DOWNLOAD_CONCURRENCY=8
PAPER_SEARCH_MCP_PARSE_CONCURRENCY=3
# Selection UI mode for paper batches requiring user confirmation:
#   auto          — (default) MCP App widget for confirmed hosts (Codex Desktop,
#                   Claude Desktop); hybrid MCP metadata + localhost checkbox for
#                   Claude Code Desktop/VS Code; localhost checkbox for Codex VS
#                   Code / CLI; numbered fallback otherwise.
#   app_only      — Only confirmed MCP Apps hosts stay widget-only. Forced
#                   confirmation flows on tentative/unsupported hosts still open
#                   localhost so a misconfiguration cannot hide the selector.
#   local_browser — Always open localhost checkbox selector (when available).
#   off           — Only return numbered fallback text list.
PAPER_SEARCH_MCP_SELECTION_UI_MODE=auto
# Optional host override when auto-detection is ambiguous.
# Use this to explicitly tell paper-search-mcp which MCP client is connecting.
#
# Four primary client scenarios (and their recommended surface):
#   codex                 — Codex Desktop (confirmed MCP Apps sandbox → inline checkbox)
#   codex_vscode          — Codex VS Code plugin (no sandbox → localhost checkbox fallback)
#   claude_code_desktop   — Claude Code Desktop standalone GUI (hybrid: MCP Apps metadata + localhost fallback)
#   claude_code_vscode    — Claude Code VS Code extension (hybrid: MCP Apps metadata + localhost fallback)
#
# Other valid values (auto-detected, rarely needed explicitly):
#   claude_desktop        — Legacy Claude Desktop (MCP Apps sandbox)
#   claude_code_cli       — Claude Code CLI / terminal (no sandbox → numbered fallback or TUI)
#   vscode_generic        — Generic VS Code with unknown AI extension
#   unknown               — Fallback
# PAPER_SEARCH_MCP_CLIENT_HOST=
# Large-batch selection policy: auto prompts when more than 10 papers are
# selected, always prompts for any non-empty batch, never disables the guard.
PAPER_SEARCH_MCP_LARGE_BATCH_SELECTION=auto
# Legacy toggle: in auto mode, true also opens the local selector for smaller
# explicit prompt flows.
PAPER_SEARCH_MCP_AUTO_OPEN_SELECTION_UI=false
# Download-selection checkbox timeout. The effective timeout scales dynamically
# with the number of displayed papers:
#   max(DOWNLOAD_SELECTION_TIMEOUT_SECONDS, num_papers × PARSE_PROMPT_TIMEOUT_PER_PAPER_SECONDS)
PAPER_SEARCH_MCP_DOWNLOAD_SELECTION_TIMEOUT_SECONDS=180
# Post-download optional MinerU prompt timeout. When a user takes no action,
# keep the PDFs only, mark the prompt terminal, and do not reopen it automatically.
# The effective timeout scales dynamically with the number of papers:
#   max(PARSE_PROMPT_TIMEOUT_SECONDS, num_papers × PARSE_PROMPT_TIMEOUT_PER_PAPER_SECONDS)
PAPER_SEARCH_MCP_PARSE_PROMPT_TIMEOUT_SECONDS=180
PAPER_SEARCH_MCP_PARSE_PROMPT_TIMEOUT_PER_PAPER_SECONDS=15
PAPER_SEARCH_MCP_PARSE_PROMPT_TIMEOUT_ACTION=no_parse
PAPER_SEARCH_MCP_PARSE_PROMPT_ALLOW_REOPEN=false
PAPER_SEARCH_MCP_MINERU_MODE=auto
PAPER_SEARCH_MCP_MINERU_BASE_URL=http://127.0.0.1:8000
PAPER_SEARCH_MCP_MINERU_BACKEND=pipeline
PAPER_SEARCH_MCP_MINERU_API_KEY=
PAPER_SEARCH_MCP_MINERU_TIMEOUT=600
PAPER_SEARCH_MCP_MINERU_EXTRACT_BASE_URL=https://mineru.net/api/v4
PAPER_SEARCH_MCP_MINERU_MODEL_VERSION=vlm
PAPER_SEARCH_MCP_MINERU_LANGUAGE=ch
PAPER_SEARCH_MCP_MINERU_IS_OCR=false
PAPER_SEARCH_MCP_MINERU_ENABLE_FORMULA=true
PAPER_SEARCH_MCP_MINERU_ENABLE_TABLE=true
PAPER_SEARCH_MCP_MINERU_POLL_INTERVAL=2
# Auto order is used when PAPER_SEARCH_MCP_MINERU_MODE=auto.
PAPER_SEARCH_MCP_MINERU_AUTO_ORDER=extract,local_api,cli,pypdf
# Set true to also write a same-name zip beside each parsed PDF.
PAPER_SEARCH_MCP_MINERU_EXPORT_ZIP=false
# Optional: comma-separated extra output formats supported by MinerU extract.
# PAPER_SEARCH_MCP_MINERU_EXTRA_FORMATS=docx,html
# Optional: page range expression accepted by MinerU extract.
# PAPER_SEARCH_MCP_MINERU_PAGE_RANGES=1-10

# Optional provider-specific keys
PAPER_SEARCH_MCP_OPENAIRE_API_KEY=
PAPER_SEARCH_MCP_CITESEERX_API_KEY=
PAPER_SEARCH_MCP_IEEE_API_KEY=
PAPER_SEARCH_MCP_ACM_API_KEY=

# ── Publisher-version download (scansci-pdf integration) ──────────────
# These keys are automatically injected into scansci-pdf to improve
# publisher PDF download success rates and rate limits.
PAPER_SEARCH_MCP_ELSEVIER_API_KEY=
PAPER_SEARCH_MCP_OPENALEX_API_KEY=

# Install with: uv sync --extra publisher  OR  pip install paper-search-mcp[publisher]
# scansci-pdf will auto-install on first use if not pre-installed.
# If auto-install fails (e.g. venv without pip), install manually:
#   uv pip install scansci-pdf[cloakbrowser]
# CloakBrowser (optional, for publisher access) requires Playwright Chromium:
#   playwright install chromium
PAPER_SEARCH_MCP_PUBLISHER_SETUP_TIMEOUT_SECONDS=10
PAPER_SEARCH_MCP_PUBLISHER_TOR_TIMEOUT_SECONDS=5
PAPER_SEARCH_MCP_PUBLISHER_CLIENT_TIMEOUT_SECONDS=120

# Optional: override env file path if needed
# PAPER_SEARCH_MCP_ENV_FILE=/absolute/path/to/.env

# Backward compatibility:
# legacy names without PAPER_SEARCH_MCP_ prefix are still supported.
