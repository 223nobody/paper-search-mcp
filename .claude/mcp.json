{
  "mcpServers": {
    "paper-search-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "--frozen",
        "--directory",
        "C:\\code\\paper-search-mcp",
        "-m",
        "paper_search_mcp.server"
      ],
      "env": {
        "PAPER_SEARCH_MCP_SEARCH_PROFILE": "pdf-cs",
        "PAPER_SEARCH_MCP_MINERU_MODE": "auto",
        "PAPER_SEARCH_MCP_MINERU_LANGUAGE": "en"
      }
    }
  }
}
